{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "node16",
    "lib": ["ES2022"],
    "outDir": "../build/main",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@electron-core/backend": [
        "../electron-core/backend/index"
      ],
      "@electron-core/oauth": [
        "../electron-core/oauth/index"
      ],
      "@electron-core/ipc": [
        "../electron-core/ipc/index"
      ],
      "@electron-core/preload": [
        "../electron-core/preload/index"
      ],
      "@electron-core/components": [
        "../electron-core/components/index"
      ],
      "@electron-core/hooks": [
        "../electron-core/hooks/index"
      ],
      "@electron-core/utils": [
        "../electron-core/utils/index"
      ]
    }
  },
  "include": ["./**/*.ts", "../electron-core/global.d.ts"],
  "exclude": ["node_modules"]
}
