{
  "name": "metaburn",
  "version": "1.0.0",
  "productName": "MetaBurn",
  "description": "Burn metadata from photos and videos.",
  "iconDescription": "A local privacy tool that strips sensitive metadata from photos and videos through drag-and-drop, removing EXIF, GPS, camera details, and device information while keeping files in place. Think of a photo or video file with sensitive data being scrubbed clean, a shield protecting privacy, or metadata layers being peeled away like an onion. Aesthetic: focused on privacy and security.",
  "private": true,
  "type": "module",
  "scripts": {
    "build:preload": "esbuild renderer/preload.ts --bundle --platform=node --target=es2022 --format=cjs --tsconfig=tsconfig.json --outfile=build/assets/preload.cjs --external:electron",
    "build:main": "esbuild main/index.ts --bundle --platform=node --target=node22 --format=esm --tsconfig=tsconfig.json --outdir=build/main --external:electron '--external:node:*'",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "build": "npm run build:preload && npm run build:main && npm run build:renderer",
    "dev:preload": "npm run build:preload",
    "dev:main": "npm run build:main && electron build/main/index.js",
    "dev:renderer": "vite dev --config vite.renderer.config.ts",
    "dev": "concurrently --kill-others --names RENDERER,MAIN \"npm run dev:renderer\" \"npm run dev:main\"",
    "start": "unset ELECTRON_RUN_AS_NODE && electron build/main/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "format": "oxfmt --write .",
    "dist": "npm run build && electron-builder --mac --publish never"
  },
  "build": {
    "appId": "com.yourcompany.metaburn",
    "productName": "MetaBurn",
    "files": [
      "build/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "icon": "app-icon.icns",
      "category": "public.app-category.utilities",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "icon": "app-icon.icns",
      "sign": false
    }
  },
  "dependencies": {
    "@radix-ui/colors": "^3.0.0",
    "@tanstack/react-query": "^5.87.4",
    "@tanstack/react-router": "^1.131.36",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.542.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@rolldown/plugin-babel": "^0.2.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.3.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^10.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.6",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^17.3.0",
    "oxfmt": "^0.26.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.20.5",
    "typescript": "^5.5.3",
    "vite": "^8.0.2"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@11.11.0+sha512-82gRxKrh/eY5UnNorkTFcdBQAGpgjWehkfGVqAGlJjejEtJZGGJUqjo3mbBTNbc5BTnPKGVtGPBZGhElujX5cw==",
  "main": "build/main/index.js"
}
